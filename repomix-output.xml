from flask import Flask, render_template, request, jsonify
from flask_cors import CORS
import requests
import random
from datetime import datetime
import pytz
import math

app = Flask(__name__)
CORS(app)

# --- CONFIGURATION ---
API_KEY = "d6b71d7e45680baf0a899cd255f300ce" #
CITY = "Kochi"

@app.route('/')
def home():
    return render_template('index.html')
@app.route('/get_status', methods=['POST'])
def get_status():
    try:
        # 1. Receive the structured appliance data from the frontend
        user_data = request.json
        
        # 2. Advanced ECE Load Calculation Engine
        # This loop goes through every appliance (ac, fan, tv, etc.)
        total_load = 0
        for appliance_id, details in user_data.items():
            if details.get('on'):
                # ECE Formula: Load = Quantity * Power Rating (Watts)
                qty = details.get('qty', 0)
                watts = details.get('watts', 0)
                total_load += (qty * watts)

        # 3. Fetch Live Kochi Weather Data
        weather_url = f"http://api.openweathermap.org/data/2.5/weather?q={CITY}&appid={API_KEY}&units=metric"
        response = requests.get(weather_url)
        data = response.json()

        if response.status_code != 200:
            return jsonify({"error": "Weather API failed"}), 500

        clouds = data.get('clouds', {}).get('all', 0)
        temp = data.get('main', {}).get('temp', 30)

        # 4. Solar Generation Curve (Time-Aware IST)
        ist = pytz.timezone('Asia/Kolkata')
        now = datetime.now(ist)
        hour = now.hour + (now.minute / 60)

        MAX_SOLAR_CAPACITY = 3000 
        if 6 <= hour <= 18:
            # Sine wave peaks at 12:00 PM (Noon)
            time_factor = math.sin(math.pi * (hour - 6) / 12)
            efficiency_factor = time_factor * (1 - (clouds / 100) * 0.75)
        else:
            efficiency_factor = 0 # Night mode in Kerala

        current_generation = MAX_SOLAR_CAPACITY * efficiency_factor

        # 5. Financials & Logic
        is_sufficient = current_generation > total_load
        savings_per_hour = (current_generation / 1000) * 7 if is_sufficient else 0
        
        # Dynamic AI Advice
        if clouds > 70:
            weather_advice = "Heavy clouds. Use high-power appliances later."
        elif is_sufficient:
            weather_advice = "Great! You are running 100% on clean energy."
        else:
            weather_advice = "Load exceeds solar. Consider switching off some appliances."

        return jsonify({
            "city": CITY,
            "time": now.strftime("%H:%M"),
            "temp": temp,
            "clouds": clouds,
            "generation_watts": round(max(0, current_generation), 2),
            "consumption_watts": total_load,
            "status": "Solar Power Sufficient" if is_sufficient else "Drawing from Grid",
            "is_solar": is_sufficient,
            "savings": round(savings_per_hour, 2),
            "advice": weather_advice
        })

    except Exception as e:
        return jsonify({"error": str(e)}), 500

if __name__ == '__main__':
    print("\n" + "="*40)
    print("SOLAR-SENSE: LIVE & TIME-AWARE")
    print(f"Current Kochi Time: {datetime.now(pytz.timezone('Asia/Kolkata')).strftime('%H:%M')}")
    print("="*40 + "\n")
    app.run(debug=True, port=5000)
