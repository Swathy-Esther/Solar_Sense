// Helper function to extract data for each appliance row
function getApplianceData(id) {
    return {
        on: document.getElementById(`${id}_toggle`).checked,
        qty: parseInt(document.getElementById(`${id}_qty`).value) || 0,
        watts: parseInt(document.getElementById(`${id}_watts`).value) || 0
    };
}

async function updateSimulation() {
    // 1. Harvest all appliance data into a single object
    const appliancePayload = {
        ac: getApplianceData('ac'),
        fan: getApplianceData('fan'),
        light: getApplianceData('light'),
        wm: getApplianceData('wm'),
        tv: getApplianceData('tv')
    };

    // 2. Select display elements
    const genDisplay = document.getElementById('gen-val');
    const savingsDisplay = document.getElementById('savings-val');
    const statusMsg = document.getElementById('status-msg');
    const tempDisplay = document.getElementById('weather-temp');
    const descDisplay = document.getElementById('weather-desc');
    const cloudDisplay = document.getElementById('cloud-val');
    const loadDisplay = document.getElementById('load-val');
    const gridStatus = document.getElementById('grid-status');

    statusMsg.innerText = "Running energy audit...";

    try {
        // 3. Post the full appliance list to Flask
        const response = await fetch('/get_status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(appliancePayload)
        });

        const data = await response.json();

        if (data.error) {
            statusMsg.innerText = "Error: " + data.error;
            return;
        }

        // 4. Update the UI with the calculated ECE-AI results
        genDisplay.innerText = data.generation_watts;
        savingsDisplay.innerText = data.savings;
        tempDisplay.innerText = `${data.temp}°C`;
        descDisplay.innerText = `Kochi: ${data.clouds}% Clouds`;
        cloudDisplay.innerText = `${data.clouds}%`;
        loadDisplay.innerText = `${data.consumption_watts} W`;
        statusMsg.innerText = `Status: ${data.status} | AI: ${data.advice}`;

        // 5. Update Status Badges
        if (data.is_solar) {
            genDisplay.className = "display-1 fw-bold text-success";
            gridStatus.innerText = "SOLAR ONLY";
            gridStatus.className = "badge bg-success";
        } else {
            genDisplay.className = "display-1 fw-bold text-danger";
            gridStatus.innerText = "GRID ACTIVE";
            gridStatus.className = "badge bg-danger";
        }

    } catch (err) {
        console.error("Fetch error:", err);
        statusMsg.innerText = "Check if Python server is running!";
    }
}
